# true = browser mock (see src/lib/mock.ts). false = call frontend server route /api/analyze.
NEXT_PUBLIC_USE_MOCK=true

# Client-visible backend base URL for silent health warm-up ping only.
NEXT_PUBLIC_API_URL=

# Server-only backend settings. Do NOT expose secrets via NEXT_PUBLIC_* variables.
BACKEND_API_BASE_URL=
BACKEND_API_KEY=
